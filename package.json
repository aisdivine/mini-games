{
  "name": "stronghold",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:farm": "vite --config games/farm/vite.config.ts",
    "build:farm": "tsc --noEmit -p games/farm/tsconfig.json && vite build --config games/farm/vite.config.ts",
    "preview:farm": "vite preview --config games/farm/vite.config.ts",
    "test:farm": "vitest run --config games/farm/vite.config.ts",
    "build:all": "npm run build && npm run build:farm"
  },
  "dependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "license": "MIT"
}
